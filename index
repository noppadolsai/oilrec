<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      body { background-color: #f4f6f9; padding-top: 10px; padding-bottom: 40px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .main-container { max-width: 650px; margin: auto; }
      .card-custom { border: none; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.06); background-color: white; }
      .nav-pills .nav-link.active { background-color: #0d6efd; }
      .kpi-card { border-radius: 12px; padding: 18px; text-center; color: white; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
      .kpi-cost { background: linear-gradient(135deg, #ff416c, #ff4b2b); }
      .kpi-liter { background: linear-gradient(135deg, #11998e, #38ef7d); }
      .filter-label { font-size: 0.85rem; font-weight: bold; color: #6c757d; }
      .badge-fuel { font-size: 0.75rem; padding: 4px 8px; border-radius: 20px; }
      .action-btn-group { display: inline-flex; gap: 4px; margin-top: 4px; }
    </style>
  </head>
  <body>
    <div class="container main-container">
      
      <ul class="nav nav-pills nav-fill mb-3 card-custom p-2" id="pills-tab" role="tablist">
        <li class="nav-item">
          <button class="nav-link active fw-bold" id="tab-form" onclick="switchView('form')">📝 บันทึกข้อมูล</button>
        </li>
        <li class="nav-item">
          <button class="nav-link fw-bold" id="tab-dashboard" onclick="switchView('dashboard')">📊 แดชบอร์ดสรุปผล</button>
        </li>
      </ul>

      <div id="formView" class="card card-custom p-4">
        <h3 class="text-center mb-4 text-primary fw-bold" id="formTitle">⛽ บันทึกการเติมน้ำมัน</h3>
        <form id="fuelForm" onsubmit="submitForm(this); return false;">
          
          <input type="hidden" id="rowIndex" value="">
          <input type="hidden" id="existingSlipUrl" value="">

          <div class="mb-3">
            <label class="form-label fw-bold">วัน/เดือน/ปี ที่เติม</label>
            <input type="date" class="form-control" id="date" name="date" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">น้ำมันที่เติม</label>
            <select class="form-select" name="fuelType" id="fuelType" required>
              <option value="" selected disabled>-- เลือกประเภทน้ำมัน --</option>
              <option value="91">91</option>
              <option value="95">95</option>
              <option value="E20">E20</option>
              <option value="Diesel">ดีเซล</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">ปั๊มที่เติม</label>
            <select class="form-select" name="station" id="station" onchange="checkStation(this)" required>
              <option value="" selected disabled>-- เลือกปั๊มน้ำมัน --</option>
              <option value="PTT">PTT</option>
              <option value="PT">PT</option>
              <option value="Shell">Shell</option>
              <option value="Bangchak">Bangchak</option>
              <option value="อื่นๆ">อื่นๆ (ระบุเอง)</option>
            </select>
            <input type="text" class="form-control mt-2 d-none" id="otherStation" placeholder="ระบุชื่อปั๊มน้ำมันอื่นๆ">
          </div>
          <div class="row">
            <div class="col-6 mb-3">
              <label class="form-label fw-bold">จำนวนลิตร</label>
              <input type="number" step="0.01" class="form-control" name="liters" id="liters" placeholder="0.00" required>
            </div>
            <div class="col-6 mb-3">
              <label class="form-label fw-bold">ราคาต่อหน่วย (บาท)</label>
              <input type="number" step="0.01" class="form-control" name="pricePerUnit" id="pricePerUnit" placeholder="0.00" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">การชำระเงิน</label>
            <div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="paymentMethod" id="cash" value="เงินสด" checked>
                <label class="form-check-label" for="cash">เงินสด</label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="paymentMethod" id="credit" value="บัตรเครดิต">
                <label class="form-check-label" for="credit">บัตรเครดิต</label>
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold" id="slipLabel">ภาพถ่าย Slip (ไม่บังคับ)</label>
            <input type="file" class="form-control" id="slip" accept="image/*">
            <div class="form-text text-muted d-none" id="slipHelp">หากไม่ต้องการเปลี่ยนรูปสลิปหลักฐานเดิม ไม่จำเป็นต้องเลือกไฟล์ใหม่</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">หมายเหตุ</label>
            <textarea class="form-control" name="notes" id="notes" rows="2" placeholder="ระบุหมายเหตุเพิ่มเติม..."></textarea>
          </div>
          
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success flex-grow-1 p-2 fw-bold" id="btnSubmit">💾 บันทึกข้อมูล</button>
            <button type="button" class="btn btn-secondary d-none p-2 fw-bold" id="btnCancelEdit" onclick="cancelEditMode()">❌ Cancel</button>
          </div>
        </form>
        <div id="statusMessage" class="mt-3 text-center fw-bold"></div>
      </div>

      <div id="dashboardView" class="card card-custom p-4 d-none">
        <h3 class="text-center mb-3 text-primary fw-bold">📊 สรุปภาพรวมการเติมน้ำมัน</h3>
        
        <div class="row g-2 mb-4 p-3 bg-light rounded-3 border">
          <div class="col-6">
            <span class="filter-label d-block mb-1">📅 เลือกปี พ.ศ.</span>
            <select class="form-select" id="filterYear" onchange="applyFilters()">
              <option value="all">ทั้งหมด ทุกปี</option>
            </select>
          </div>
          <div class="col-6">
            <span class="filter-label d-block mb-1">🌙 เลือกเดือน</span>
            <select class="form-select" id="filterMonth" onchange="applyFilters()">
              <option value="all">ทั้งหมด ทุกเดือน</option>
              <option value="1">มกราคม</option>
              <option value="2">กุมภาพันธ์</option>
              <option value="3">มีนาคม</option>
              <option value="4">เมษายน</option>
              <option value="5">พฤษภาคม</option>
              <option value="6">มิถุนายน</option>
              <option value="7">กรกฎาคม</option>
              <option value="8">สิงหาคม</option>
              <option value="9">กันยายน</option>
              <option value="10">ตุลาคม</option>
              <option value="11">พฤศจิกายน</option>
              <option value="12">ธันวาคม</option>
            </select>
          </div>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-6">
            <div class="kpi-card kpi-cost">
              <small class="d-block text-uppercase fw-bold opacity-75 mb-1">ค่าใช้จ่ายรวมช่วงนี้</small>
              <span class="fs-3 fw-bold" id="totalCost">0.00</span> <small class="text-white-50">บาท</small>
            </div>
          </div>
          <div class="col-6">
            <div class="kpi-card kpi-liter">
              <small class="d-block text-uppercase fw-bold opacity-75 mb-1">จำนวนลิตรรวมช่วงนี้</small>
              <span class="fs-3 fw-bold" id="totalLiters">0.00</span> <small class="text-white-50">ลิตร</small>
            </div>
          </div>
        </div>

        <h5 class="fw-bold mb-3 text-secondary">📋 รายการประวัติการเติมน้ำมัน</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle" style="font-size: 0.9rem;">
            <thead class="table-dark">
              <tr>
                <th style="width: 20%;">วันที่</th>
                <th style="width: 50%;">รายละเอียดค่าน้ำมัน</th>
                <th style="width: 13%;" class="text-end">ลิตร</th>
                <th style="width: 17%;" class="text-end">รวม (บาท)</th>
              </tr>
            </thead>
            <tbody id="dashboardTableBody">
              <tr>
                <td colspan="4" class="text-center text-muted py-4">⏳ กำลังโหลดข้อมูล...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <script>
      var rawRecords = []; // คลังจัดเก็บข้อมูลดิบทั้งหมด

      document.getElementById('date').value = new Date().toISOString().substring(0, 10);

      function switchView(view) {
        var tabs = document.getElementById('pills-tab').getElementsByTagName('button');
        if (view === 'form') {
          document.getElementById('formView').classList.remove('d-none');
          document.getElementById('dashboardView').classList.add('d-none');
          tabs[0].classList.add('active');
          tabs[1].classList.remove('active');
        } else {
          document.getElementById('formView').classList.add('d-none');
          document.getElementById('dashboardView').classList.remove('d-none');
          tabs[0].classList.remove('active');
          tabs[1].classList.add('active');
          loadDashboardData();
        }
      }

      function checkStation(select) {
        var otherInput = document.getElementById('otherStation');
        if(select.value === 'อื่นๆ') {
          otherInput.classList.remove('d-none');
          otherInput.required = true;
        } else {
          otherInput.classList.add('d-none');
          otherInput.required = false;
        }
      }

      function loadDashboardData() {
        document.getElementById('dashboardTableBody').innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">⏳ กำลังประมวลผลข้อมูลล่าสุด...</td></tr>';
        google.script.run
          .withSuccessHandler(function(data) {
            rawRecords = data;
            populateYearDropdown();
            applyFilters();
          })
          .getDashboardData();
      }

      function populateYearDropdown() {
        var yearSelect = document.getElementById('filterYear');
        var selectedValue = yearSelect.value;
        yearSelect.innerHTML = '<option value="all">ทั้งหมด ทุกปี</option>';
        
        var uniqueYears = [];
        rawRecords.forEach(function(item) {
          if (item.year && !uniqueYears.includes(item.year)) { uniqueYears.push(item.year); }
        });
        
        uniqueYears.sort(function(a, b){ return b - a; });
        uniqueYears.forEach(function(year) {
          var option = document.createElement('option');
          option.value = year;
          option.text = "ปี พ.ศ. " + (year + 543);
          yearSelect.appendChild(option);
        });

        if(selectedValue && yearSelect.querySelector(`option[value="${selectedValue}"]`)) {
          yearSelect.value = selectedValue;
        }
      }

      function applyFilters() {
        var targetYear = document.getElementById('filterYear').value;
        var targetMonth = document.getElementById('filterMonth').value;

        var filteredRecords = [];
        var totalCost = 0;
        var totalLiters = 0;

        rawRecords.forEach(function(item) {
          var matchYear = (targetYear === 'all' || item.year.toString() === targetYear);
          var matchMonth = (targetMonth === 'all' || item.month.toString() === targetMonth);

          if (matchYear && matchMonth) {
            filteredRecords.push(item);
            totalCost += item.totalAmount;
            totalLiters += item.liters;
          }
        });

        document.getElementById('totalCost').innerText = totalCost.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('totalLiters').innerText = totalLiters.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2});

        var tbody = document.getElementById('dashboardTableBody');
        tbody.innerHTML = "";

        if (filteredRecords.length === 0) {
          tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">❌ ไม่พบประวัติการเติมน้ำมันในช่วงเวลาที่เลือก</td></tr>';
          return;
        }

        // เรียงจากใหม่ไปเก่าเพื่อแสดงผล
        var displayList = [...filteredRecords].reverse();

        displayList.forEach(function(item) {
          var badgeClass = "bg-primary";
          if(item.fuelType === "91") badgeClass = "bg-warning text-dark";
          if(item.fuelType === "E20") badgeClass = "bg-success";
          if(item.fuelType === "Diesel") badgeClass = "bg-secondary";

          var slipButton = "";
          if(item.slipUrl) {
            slipButton = `<a href="${item.slipUrl}" target="_blank" class="btn btn-sm btn-outline-danger py-0 px-1" style="font-size:0.7rem;">📎 สลิป</a>`;
          }

          // ปุ่มแก้ไขรายการ ผูกเข้ากับฟังก์ชันเปิดโหมดดึงข้อมูลย้อนกลับ
          var editButton = `<button type="button" class="btn btn-sm btn-outline-primary py-0 px-1" style="font-size:0.7rem;" onclick="activateEditMode(${item.rowIndex})">✏️ แก้ไข</button>`;

          var noteText = item.notes ? `<div class="text-muted small mt-1" style="font-size:0.8rem;">规格: ${item.notes}</div>` : "";

          var row = `<tr>
            <td class="text-secondary fw-semibold">${item.dateStr}</td>
            <td>
              <div>
                <span class="badge ${badgeClass} badge-fuel">แก๊สโซฮอล์ ${item.fuelType}</span>
                <span class="badge bg-light text-dark border border-secondary-subtle badge-fuel">${item.station}</span>
              </div>
              <div class="action-btn-group">
                ${slipButton}
                ${editButton}
              </div>
              ${noteText}
            </td>
            <td class="text-end fw-bold text-dark">${item.liters.toFixed(2)}</td>
            <td class="text-end fw-bold text-danger">${item.totalAmount.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
          </tr>`;
          tbody.innerHTML += row;
        });
      }

      // ================= ฟังก์ชันหัวใจหลักสำหรับการแก้ไขข้อมูลหน้าบ้าน =================
      function activateEditMode(rowIndex) {
        // ค้นหารายการจากเลขแถวพิกัด
        var item = rawRecords.find(function(r) { return r.rowIndex === rowIndex; });
        if (!item) return;

        var form = document.getElementById('fuelForm');
        
        // 1. ตรึงคีย์ล็อกเก็บตัวเลขแถวเดิมและ URL รูปสลิปเดิมไว้ในฟิลด์ซ่อน
        document.getElementById('rowIndex').value = item.rowIndex;
        document.getElementById('existingSlipUrl').value = item.slipUrl;

        // 2. ป้อนข้อมูลเก่าไหลกลับคืนหน้ากาก UI ฟอร์มแต่ละช่อง
        document.getElementById('date').value = item.dateIso;
        document.getElementById('fuelType').value = item.fuelType;
        document.getElementById('liters').value = item.liters;
        document.getElementById('pricePerUnit').value = item.pricePerUnit;
        document.getElementById('notes').value = item.notes;

        // จัดการวิเคราะห์ปั๊มน้ำมันอื่นๆ
        var standardStations = ["PTT", "PT", "Shell", "Bangchak"];
        if (standardStations.includes(item.station)) {
          document.getElementById('station').value = item.station;
          document.getElementById('otherStation').classList.add('d-none');
          document.getElementById('otherStation').value = "";
        } else {
          document.getElementById('station').value = "อื่นๆ";
          document.getElementById('otherStation').classList.remove('d-none');
          document.getElementById('otherStation').value = item.station;
        }

        // เลือกวิทยุ (Radio) วิธีชำระเงิน
        if (item.paymentMethod === "เงินสด") {
          document.getElementById('cash').checked = true;
        } else {
          document.getElementById('credit').checked = true;
        }

        // 3. ปรับแต่งสภาพ UI ให้ผู้ใช้รู้ตัวว่ากำลังทำงานอยู่ใน "โหมดแก้ไข"
        document.getElementById('formTitle').innerText = "✏️ แก้ไขค่าน้ำมัน (แถวที่ " + rowIndex + ")";
        document.getElementById('slipLabel').innerText = "เปลี่ยนรูปถ่าย Slip ใหม่ (เลือกเมื่อต้องการเปลี่ยน)";
        document.getElementById('slipHelp').classList.remove('d-none');
        
        var btnSubmit = document.getElementById('btnSubmit');
        btnSubmit.innerText = "✏️ อัปเดตแก้ไขข้อมูล";
        btnSubmit.className = "btn btn-warning flex-grow-1 p-2 fw-bold text-dark";
        
        document.getElementById('btnCancelEdit').classList.remove('d-none');
        document.getElementById('statusMessage').innerText = "";

        // สลับมุมมองย้อนกลับไปหน้าฟอร์มเพื่อแก้ไข
        switchView('form');
      }

      // ฟังก์ชันสำหรับเคลียร์ฟอร์มกลับคืนสู่สภาพเดิม (โหมดป้อนใหม่)
      function cancelEditMode() {
        document.getElementById('fuelForm').reset();
        document.getElementById('rowIndex').value = "";
        document.getElementById('existingSlipUrl').value = "";
        document.getElementById('otherStation').classList.add('d-none');
        document.getElementById('date').value = new Date().toISOString().substring(0, 10);
        
        // คืนร่างปุ่มเซฟเป็นสีเขียว
        document.getElementById('formTitle').innerText = "⛽ บันทึกการเติมน้ำมัน";
        document.getElementById('slipLabel').innerText = "ภาพถ่าย Slip (ไม่บังคับ)";
        document.getElementById('slipHelp').classList.add('d-none');
        
        var btnSubmit = document.getElementById('btnSubmit');
        btnSubmit.innerText = "💾 บันทึกข้อมูล";
        btnSubmit.className = "btn btn-success flex-grow-1 p-2 fw-bold";
        
        document.getElementById('btnCancelEdit').className = "btn btn-secondary d-none p-2 fw-bold";
      }

      function submitForm(form) {
        var btn = document.getElementById('btnSubmit');
        var status = document.getElementById('statusMessage');
        btn.disabled = true;
        btn.innerText = "⏳ กำลังบันทึกข้อมูลระบบ...";
        status.innerText = "";

        var fileInput = document.getElementById('slip');
        var file = fileInput.files[0];
        
        var stationValue = form.station.value;
        if(stationValue === 'อื่นๆ') { stationValue = document.getElementById('otherStation').value; }

        var formData = {
          rowIndex: document.getElementById('rowIndex').value,
          existingSlipUrl: document.getElementById('existingSlipUrl').value,
          date: form.date.value,
          fuelType: form.fuelType.value,
          station: stationValue,
          liters: form.liters.value,
          pricePerUnit: form.pricePerUnit.value,
          paymentMethod: form.paymentMethod.value,
          notes: form.notes.value
        };

        if (file) {
          var reader = new FileReader();
          reader.onload = function(e) {
            formData.slipFile = {
              bytes: e.target.result.split(',')[1],
              mimeType: file.type,
              name: file.name
            };
            sendToServer(formData);
          };
          reader.readAsDataURL(file);
        } else {
          formData.slipFile = null;
          sendToServer(formData);
        }
      }

      function sendToServer(formData) {
        var status = document.getElementById('statusMessage');
        var btn = document.getElementById('btnSubmit');

        google.script.run
          .withSuccessHandler(function(response) {
            btn.disabled = false;
            // สั่งคืนค่าฟอร์มกลับสู่โหมดบันทึกปกติเสมอหลังเซฟสำเร็จ
            var wasUpdate = document.getElementById('rowIndex').value ? true : false;
            cancelEditMode();
            
            if(response.status === "success") {
              status.className = "mt-3 text-center fw-bold text-success";
              status.innerText = response.message;
              
              // หากกดแก้ไขข้อมูลเสร็จสิ้น ให้เปิดหน้าจอแดชบอร์ดรีโหลดข้อมูลใหม่เพื่อดูผลลัพธ์ทันที
              if (wasUpdate) {
                setTimeout(function(){ switchView('dashboard'); }, 1000);
              }
            } else {
              status.className = "mt-3 text-center fw-bold text-danger";
              status.innerText = "❌ เกิดข้อผิดพลาด: " + response.message;
            }
          })
          .withFailureHandler(function(err) {
            btn.disabled = false;
            status.className = "mt-3 text-center fw-bold text-danger";
            status.innerText = "❌ ติดขัดปัญหาทางเทคนิค: " + err;
          })
          .saveRecord(formData);
      }
    </script>
  </body>
</html>
